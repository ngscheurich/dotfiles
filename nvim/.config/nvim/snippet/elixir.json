{
  "Define Module": {
    "prefix": ["defmodule"],
    "body": [
      "defmodule ${1:name} do",
      "  ${0}",
      "end"
    ]
  },

  "Define Function": {
    "prefix": ["def"],
    "body": [
      "def ${1:name}(${2:params}) do",
      "  ${0}",
      "end"
    ]
  },

  "Define Private Function": {
    "prefix": ["defp"],
    "body": [
      "defp ${1:name}(${2:params}) do",
      "  ${0}",
      "end"
    ]
  },

  "Document Module": {
    "prefix": ["@moduledoc"],
    "body": ["@moduledoc \"\"\"", "  ${1}", "\"\"\"", "${0}"]
  },

  "Document Function": {
    "prefix": ["@doc"],
    "body": ["@doc \"\"\"", "  ${1}", "\"\"\"", "  ${0}"]
  },

  "Inspect Term": {
    "prefix": ["insp"],
    "body": "IO.inspect(${1}, label: \"${1}\")${0}"
  },

  "Pry Here": {
    "prefix": ["pry"],
    "body": ["require IEx", "IEx.pry"]
  },

  "LiveView Module": {
    "prefix": ["lvmod"],
    "body": [
      "defmodule ${1:module}.$2 do",
      "  use $1, :live_view",
      "  @impl true",
      "  def mount(params, session, socket) do",
      "    {:ok, assign(socket, message: \"$1.$2\")}",
      "  end",
      "",
      "  @impl true",
      "  def render(assigns) do",
      "    ~L\"\"\"",
      "    <%= @message %>",
      "    \"\"\"",
      "  end",
      "  $0",
      "end"
    ]
  }
}
