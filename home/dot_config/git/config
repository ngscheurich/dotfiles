[user]
	name = N. G. Scheurich
	email = nick@scheurich.me
	signingKey = ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIBzHyqJW+HIsWjMesMW/i6QPHaaQ9UsUIoONMH9yqPjN
[core]
  editor = nvim
	excludesfile = ~/.config/git/ignore
  pager = hunk pager
[init]
	defaultBranch = main
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
[tag]
	gpgsign = true
[commit]
	gpgsign = true
[merge]
  conflictstyle = diff3
  tool = vimdiff
[fetch]
  prune = true
  prunetags = true
[push]
  default = current
  autoSetupRemote = true
[pull]
  ff = only
[rebase]
  autosquash = true
[help]
  autocorrect = prompt
[alias]
  am = commit --amend --message
  br = branch
  cm = commit
  cma = commit --all
  cmf = commit --fixup
  cmp = commit --patch
  co = checkout
  d = diff
  dl = log -p --ext-diff
  ds = show --ext-diff
  fu = !~/.local/share/grimoire/git_fuckup.sh
  prov = !~/.local/share/grimoire/git_provenance.sh
  pub = push --set-upstream origin HEAD
  rb = rebase
  rba = rebase --abort
  rbc = rebase --continue
  st = status
  unstage = reset --soft HEAD^

# vim:ft=gitconfig
